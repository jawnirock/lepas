<div id="secret-gate" data-password="{{ collection.metafields.custom.password }}">
  <div id="secret-form-wrap">
    <form id="secret-form" autocomplete="off">
      <input type="password" id="secret-input" placeholder="Enter password" autocomplete="off">
      <button type="submit">Enter</button>
      <p id="secret-error" style="display:none;">Incorrect password.</p>
    </form>
  </div>
</div>

<div id="secret-content" style="display:none;">

<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "ItemList",
  "name": "{{ collection.title | escape }}",
  "itemListElement": [
    {% for product in collection.products %}
      {
        "@type": "ListItem",
        "position": {{ forloop.index }},
        "url": "{{ shop.url }}{{ product.url }}",
        "item": {
          "@type": "Product",
          "name": "{{ product.title | escape }}",
          "image": "{% if product.featured_image %}{{ product.featured_image | image_url: height: 400 }}{% endif %}",
          "sku": "{{ product.sku }}",
          "brand": { "@type": "Brand", "name": "{{ product.vendor }}" },
          "offers": {
            "@type": "Offer",
            "url": "{{ shop.url }}{{ product.url }}",
            "priceCurrency": "{{ cart.currency.iso_code }}",
            "price": "{{ product.price | money_without_currency }}",
            "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
            "seller": { "@type": "Organization", "name": "{{ shop.name }}" }
          }
        }
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
</script>

<div class="content-fit">
  <h1 class="products-title" hidden>{{ collection.title }}</h1>

  {% paginate collection.products by 12 %}
    <div id="products-grid" class="products">
      {% for product in collection.products %}
        {% render 'product', product: product %}
      {% endfor %}
    </div>

    <nav id="server-pagination" class="pagination" aria-label="Pagination">
      {% if paginate.previous %}
        <a href="{{ paginate.previous.url }}" class="prev" rel="prev">Prev</a>
      {% endif %}

      {% for part in paginate.parts %}
        {% if part.is_link %}
          <a href="{{ part.url }}">{{ part.title }}</a>
        {% else %}
          <span class="current">{{ part.title }}</span>
        {% endif %}
      {% endfor %}

      {% if paginate.next %}
        <a href="{{ paginate.next.url }}" class="next" rel="next">Next</a>
      {% endif %}
    </nav>

    <div id="infinite-scroll-sentinel" aria-hidden="true"></div>
    <div id="infinite-loading" role="status" aria-live="polite" aria-atomic="true">Loading…</div>
  {% endpaginate %}
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var grid = document.getElementById('products-grid');
  var pagination = document.getElementById('server-pagination');
  var sentinel = document.getElementById('infinite-scroll-sentinel');
  var loadingUI = document.getElementById('infinite-loading');

  if (!grid || !pagination || !sentinel || !loadingUI) return;

  pagination.style.display = 'none';
  loadingUI.style.display = 'none';

  var nextLinkEl = pagination.querySelector('.next');
  var nextURL = nextLinkEl ? nextLinkEl.getAttribute('href') : null;
  var isLoading = false;

  var DELAY_BETWEEN_LOADS = 1500;
  var observerArmed = false;

  function armObserverOnceUserScrolls() {
    if (observerArmed) return;
    if (window.scrollY > 80) {
      observer.observe(sentinel);
      observerArmed = true;
      window.removeEventListener('scroll', armObserverOnceUserScrolls, { passive: true });
    }
  }

  function showLoading(show) {
    loadingUI.style.display = show ? 'block' : 'none';
  }

  function delay(ms) {
    return new Promise(function(resolve) { setTimeout(resolve, ms); });
  }

  async function loadMore() {
    if (isLoading || !nextURL) return;

    isLoading = true;
    showLoading(true);
    observer.unobserve(sentinel);

    try {
      var url = new URL(nextURL, window.location.origin);
      url.searchParams.set('view', 'products-only');

      var res = await fetch(url.toString(), { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
      if (!res.ok) throw new Error('Network error: ' + res.status);

      var html = await res.text();
      var doc = new DOMParser().parseFromString(html, 'text/html');

      var newItems = doc.querySelectorAll('.products > *');
      newItems.forEach(function(el) {
        grid.appendChild(el);
        $(el).find('.product-card-slider').slick({
          dots: false,
          arrows: true,
          prevArrow: `<button type="button" class="slick-prev"><img src="{{ 'newarrow.png' | asset_url }}" alt=""></button>`,
          nextArrow: `<button type="button" class="slick-next"><img src="{{ 'newarrow.png' | asset_url }}" alt=""></button>`,
          infinite: false,
          responsive: [
            {
              breakpoint: 769,
              settings: {
                dots: true,
                arrows: false
              }
            }
          ]
        });
      });

      var newNext = doc.querySelector('.pagination .next');
      nextURL = newNext ? newNext.getAttribute('href') : null;

      await delay(DELAY_BETWEEN_LOADS);

      if (nextURL) observer.observe(sentinel);
    } catch (err) {
      console.error('Infinite scroll failed:', err);
    } finally {
      isLoading = false;
      showLoading(false);
    }
  }

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) loadMore();
    });
  }, { root: null, rootMargin: '0px', threshold: 0 });

  if (nextURL) {
    window.addEventListener('scroll', armObserverOnceUserScrolls, { passive: true });
    armObserverOnceUserScrolls();
  }
});
</script>

</div>

<script>
(function() {
  var gate = document.getElementById('secret-gate');
  var content = document.getElementById('secret-content');
  var form = document.getElementById('secret-form');
  var input = document.getElementById('secret-input');
  var error = document.getElementById('secret-error');
  var correctPassword = gate.dataset.password;
  var sessionKey = 'secret_access_{{ collection.handle }}';

  function unlock() {
    gate.style.display = 'none';
    content.style.display = 'block';
    $(window).trigger('resize');
  }

  if (sessionStorage.getItem(sessionKey) === '1') {
    unlock();
    return;
  }

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    if (input.value === correctPassword) {
      sessionStorage.setItem(sessionKey, '1');
      unlock();
    } else {
      error.style.display = 'block';
      input.value = '';
      input.focus();
    }
  });
})();
</script>
