{% if settings.banner_text != blank %}
  <div class="banner" style="background-color: {{ settings.banner_bg_color }}; color: {{ settings.banner_text_color }};">
    
    {% if settings.banner_link != blank %}
      <a 
        href="{{ settings.banner_link }}" 
        class="banner-text"
        style="color: {{ settings.banner_text_color }}"
        {% if settings.banner_link_new_tab %}target="_blank" rel="noopener"{% endif %}
      >
        {{ settings.banner_text }}
      </a>
    {% else %}
      <div class="banner-text">{{ settings.banner_text }}</div>
    {% endif %}

    <img class="banner-close" src="{{ 'close.svg' | asset_url }}" alt="">
  </div>
{% endif %}



<header class="header">
    <a class="header-logo" href="/">
      <img src="{{ 'logo.svg' |  asset_url }}" alt="">
    </a>
    <div class="mobile">
      <div style="background-image: url({{ 'search.svg' |  asset_url }});" class="header-search-open mobile"></div>
      <div style="background-image: url({{ 'cart.svg' |  asset_url }});" class="header-cart mobile"></div>
      <div style="background-image: url({{ 'menu.svg' |  asset_url }});" class="header-menu-toggle mobile"></div>
      <div style="background-image: url({{ 'close.svg' |  asset_url }}); display: none;" class="header-menu-toggle mobile"></div>
    </div>
</header>

<div class="menu menu-left">
  {% if collection.handle == 'archivesale' %}
    <a href="/collections/archivesale" {% unless current_tags %}class="active"{% endunless %}>ALL</a>
    <a href="/collections/archivesale/archivesandals" {% if current_tags contains 'sandals' or current_tags contains 'SANDALS' %}class="active"{% endif %}>SANDALS</a>
    <a href="/collections/archivesale/archivepumps" {% if current_tags contains 'pumps' or current_tags contains 'PUMPS' %}class="active"{% endif %}>PUMPS</a>
    <a href="/collections/archivesale/archivemules" {% if current_tags contains 'mules' or current_tags contains 'MULES' %}class="active"{% endif %}>MULES</a>
    <a href="/collections/archivesale/archiveflats" {% if current_tags contains 'flats' or current_tags contains 'FLATS' %}class="active"{% endif %}>FLATS</a>
    <a href="/collections/archivesale/archiveheels" {% if current_tags contains 'heels' or current_tags contains 'HEELS' %}class="active"{% endif %}>HEELS</a>
    <a href="/collections/archivesale/archiveboots" {% if current_tags contains 'boots' or current_tags contains 'BOOTS' %}class="active"{% endif %}>BOOTS</a>
  {% elsif request.path contains '/collections/' or request.path contains '/products/' or request.path contains '/pages/new-in' %}
    <a href="#" class="shop-toggler">SHOP</a>      
    <div style="height: {{ settings.menu_left_space_1 }}"></div>
      <div class="shop-toggled">
      {% assign home_url = shop.url | append: '/' %}
      {% for link in linklists.categories.links %}
        {% if link.url == '/' or link.url == home_url %}
          <a href="/collections/{{ link.title | downcase | replace: ' ', '-' }}">
            {{ link.title | upcase }}
          </a>
        {% else %}
          <a href="{{ link.url }}">
            {{ link.title | upcase }}
          </a>
        {% endif %}
      {% endfor %}
      <div style="height: {{ settings.menu_left_space_2 }}"></div>
    </div>
    {% else %}
      <a href="/collections/view-all" class="shop-toggler">SHOP</a>        
      <div style="height: {{ settings.menu_left_space_1 }}"></div>
    {% endif %}

  {% unless collection.handle == 'archivesale' %}
    <a href="/pages/about">ABOUT</a>
    {% if template.suffix == 'collections' %}
      <div style="height: {{ settings.menu_left_space_1 }}"></div>    
      <a href="#" class="shop-toggler">IMAGES</a>
        <div class="shop-toggled">
          {% for link in linklists.image-collections.links -%}
            <a href="{{link.url}}">
              {{ link.title | upcase }}
            </a>
          {%- endfor %}
          <div style="height: {{ settings.menu_left_space_1 }}"></div>    
        </div>
    {% else %}
    {% for link in linklists.image-collections.links -%}
      {% if forloop.first %}
        <a href="{{link.url}}">
          IMAGES
        </a>
      {% endif %}
    {%- endfor %}
    {% endif %}
  {% endunless %}
</div>

<div class="menu menu-right">
    <div class="header-search">
    <form action="/search" method="get" role="search">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="SEARCH" />
      <input type="hidden" name="type" value="product">
    </form>
    </div>
    <a class="cart-button" href="#">  CART (<span id="cart-count">{{ cart.item_count }}</span>)
    </a>
    {% if customer %}<a href="{{ routes.account_url }}">ACCOUNT</a>{% else %}<a href="{{ routes.account_login_url }}">LOG IN</a>{% endif %}
</div>

<div class="menu-mobile-search">
    <form action="/search" method="get" role="search">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="SEARCH" />
      <input type="hidden" name="type" value="product">
    </form>
</div>
<div class="menu-mobile">
    <a class="cart-button" href="#">  CART (<span id="cart-count">{{ cart.item_count }}</span>)
    </a>
    {% if customer %}<a href="{{ routes.account_url }}">ACCOUNT</a>{% else %}<a href="{{ routes.account_login_url }}">LOG IN</a>{% endif %}
    <div style="height: {{ settings.menu_left_space_1 }}"></div>
    {% if request.path contains '/collections/' or request.path contains '/products/' or request.path contains '/pages/new-in' %}
    <a href="#" class="shop-toggler">SHOP</a>      
    <div style="height: {{ settings.menu_left_space_1 }}"></div>
      <div class="shop-toggled">
      {% for link in linklists.categories.links %}
        {% if link.url == '/' or link.url == home_url %}
          <a href="/collections/{{ link.title | downcase | replace: ' ', '-' }}">
            {{ link.title | upcase }}
          </a>
        {% else %}
          <a href="{{ link.url }}">
            {{ link.title | upcase }}
          </a>
        {% endif %}
      {% endfor %}
      <div style="height: {{ settings.menu_left_space_2 }}"></div>
    </div>
    {% else %}
      <a href="/collections/view-all" class="shop-toggler">SHOP</a>        
      <div style="height: {{ settings.menu_left_space_1 }}"></div>
    {% endif %}  
    {% if template.suffix == 'collections' %}
      <div style="height: {{ settings.menu_left_space_1 }}"></div>    
      <a href="#" class="shop-toggler">IMAGES</a>
        <div class="shop-toggled">
          {% for link in linklists.image-collections.links -%}
            <a href="{{link.url}}">
              {{ link.title | upcase }}
            </a>
          {%- endfor %}
          <div style="height: {{ settings.menu_left_space_1 }}"></div>    
        </div>
    {% else %}
    {% for link in linklists.image-collections.links -%}
      {% if forloop.first %}
        <a href="{{link.url}}">
          IMAGES
        </a>
      {% endif %}
    {%- endfor %}
    {% endif %}      
    <a href="/pages/about">ABOUT</a>
</div>

<div class="cart">
    <div class="cart-overlay" style="background-color: {{ settings.cart_bg_color }}; opacity: {{ settings.cart_bg_opacity }};"></div>
    <div class="cart-content" id="sidebar-cart">
      {% render 'cart' %}
    </div>
    <img class="cart-close" src="{{ 'close.svg' |  asset_url }}" alt="">
</div>

<div class="pagespecial">

</div>

<style>
  :root {
    --menu-color: {{ settings.menu_background | color: 'hex' }};
  }
</style>