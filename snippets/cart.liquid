<div id="cart-container">
    <div class="cart-title">CART (<span id="cart-count-top">{{ cart.item_count }}</span>)</div>
    <div class="cart-items">
        {% for item in cart.items %}
            <div class="cart-item" data-variant-id="{{ item.variant.id }}">
                <div>
                    <img src="{{ item.image | image_url: height: 800 }}" alt="">
                </div>
                <div>
                    {{ item.product.title }} <br>
                    {% if item.original_price > item.final_price %}
                        <span class="old-price" style="text-decoration: line-through; margin-right: 5px;">
                            {{ item.original_price | money }}
                        </span>
                        <span class="sale-price">
                            {{ item.final_price | money }}
                        </span>
                        {% else %}
                        <span class="regular-price">
                            {{ item.final_price | money }}
                        </span>
                        {% endif %}
                    <br><br>

                    
                    {% unless item.product.has_only_default_variant %}
                    <div class="cart-item-size">
                        <label for="size-select-{{ item.variant.id }}">SIZE:</label>
                        <select class="size-select" id="size-select-{{ item.variant.id }}" data-line-item-key="{{ item.key }}" data-current-variant-id="{{ item.variant.id }}" data-quantity="{{ item.quantity }}">
                            {% for variant in item.product.variants %}
                                {% if variant.inventory_quantity > 0 %}
                                    <option class="stock" value="{{ variant.id }}" {% if variant.id == item.variant.id %}selected{% endif %}>
                                        {{ variant.title }}
                                    </option>
                                {% else %}
                                    <option class="no-stock" value="{{ variant.id }}" {% if variant.id == item.variant.id %}selected{% endif %} disabled>
                                        {{ variant.title }} - Sold Out
                                    </option>
                                {% endif %}
                            {% endfor %}
                        </select>
                    </div>
                    {% endunless %}
                    {% assign colors = item.product.metafields.custom.other_colors.value %}    
                    {% for color in colors %}
                        {% if color.product_url == item.product.url %}
                            {% if color.color_name %}
                                <div>
                                    COLOR: {{ color.color_name }}<br>
                                </div>
                            {% endif %}
                        {% endif %}
                    {% endfor %}  
                    {% if item.product.metafields.custom.pre_order %}                
                        {{ item.product.metafields.custom.pre_order | metafield_tag  }}
                    {% endif %}                    
                    <span>QUANTITY</span>:
                    <div class="cart-item-quantity">
                        <button class="quantity-button" data-variant-id="{{ item.id }}" data-action="decrement">-</button>
                        <span class="quantity-display" data-variant-id="{{ item.id }}">{{ item.quantity }}</span>
                        <button class="quantity-button" data-variant-id="{{ item.id }}" data-action="increment">+</button>                        
                    </div>
                    <button class="remove-button" data-variant-id="{{ item.variant.id }}">Remove</button>
                </div>
            </div>    
        {% endfor %}
    </div>
    <div class="cart-footer">
        <div class="cart-footer-top">
            <span>
                SUBTOTAL:
            </span>
            <span>{{cart.total_price | money}}</span>
        </div>
        <div class="cart-footer-buttons">
            <a class="checkout" href="/checkout">Proceed to checkout</a>
            <a class="bag" href="/cart">VIEW CART</a>
        </div>
    </div>
</div>



